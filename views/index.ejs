<!DOCTYPE html>
<html lang="en">
<%- include("partials/head") %>
<body>
  <%- include("partials/header") %>
  <%- include("partials/navigation") %>

  <main>
      <section class="hero">
          <h2>Welcome to CSE Motors!</h2>
          <div class="hero-content">
              <div class="hero-text">
                  <h3>DMC Delorean</h3>
                  <ul>
                      <li>3 Cup holders</li>
                      <li>Superman doors</li>
                      <li>Fuzzy dice!</li>
                  </ul>
                  <a href="#" class="cta-button">Own Today</a>
              </div>
              <img src="/images/delorean.png" alt="DMC Delorean" class="hero-image">
          </div>
      </section>

      <section class="reviews">
          <h3>DMC Delorean Reviews</h3>
          <ul>
              <li>"So fast it's almost like traveling in time." (4/5)</li>
              <li>"Coolest ride on the road." (4/5)</li>
              <li>"I'm feeling McFly!" (5/5)</li>
              <li>"The most futuristic ride of our day." (4/5)</li>
              <li>"80's livin and I love it!" (5/5)</li>
          </ul>
      </section>

      <section class="upgrades">
          <h3>Delorean Upgrades</h3>
          <div class="upgrades-grid">
              <div class="upgrade-item">
                  <img src="/images/flux-capacitor.png" alt="Flux Capacitor">
                  <p>Flux Capacitor</p>
              </div>
              <div class="upgrade-item">
                  <img src="/images/flame-decals.png" alt="Flame Decals">
                  <p>Flame Decals</p>
              </div>
              <div class="upgrade-item">
                  <img src="/images/bumper-stickers.png" alt="Bumper Stickers">
                  <p>Bumper Stickers</p>
              </div>
              <div class="upgrade-item">
                  <img src="/images/hub-caps.png" alt="Hub Caps">
                  <p>Hub Caps</p>
              </div>
          </div>
      </section>
  </main>

  <%- include("partials/footer") %>
</body>
</html>
